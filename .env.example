# ═══════════════════════════════════════════════════════════════════════════════
# UNITGROUP - PRODUCTION CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in real values
# NEVER commit .env to Git - it contains secrets!

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DEPLOYMENT & ENVIRONMENT
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NODE_ENV=production
DEBUG=false
PORT=8000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DOMAIN & URLS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DOMAIN=unitgroup.tech
PUBLIC_BASE_URL=https://unitgroup.tech
MINIAPP_URL=https://unitgroup.tech/app/

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TELEGRAM BOT (Main)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_GROUP_ID=-1001234567890
TELEGRAM_ADMIN_ID=123456789

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TELEGRAM MONITORING ALERTS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ALERT_BOT_TOKEN=optional_alert_bot_token
ALERT_CHAT_ID=optional_alert_chat_id

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# EMAIL (Yandex Mail for order intake)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
YANDEX_EMAIL=sales@company.ru
YANDEX_PASSWORD=app_specific_password_not_main_password
YANDEX_IMAP_SERVER=imap.yandex.ru
YANDEX_IMAP_PORT=993
PROCESS_ONLY_UNSEEN=false
EMAIL_CHECK_INTERVAL=300

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DATABASE (PostgreSQL in Docker)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
POSTGRES_USER=unitgroup
POSTGRES_PASSWORD=strong_postgres_password_here
POSTGRES_DB=unitgroup
DATABASE_URL=postgresql://unitgroup:password@db:5432/unitgroup

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# COMPANY INFO
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
COMPANY_NAME=UNITGROUP
COMPANY_EMAIL=sales@unitgroup.tech
COMPANY_PHONE=+7 (999) 999-99-99
COMPANY_SITE=unitgroup.tech

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI & INTEGRATIONS (Optional)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ENABLE_AI=false
ANTHROPIC_API_KEY=optional_api_key
OPENAI_API_KEY=optional_api_key

# ═══════════════════════════════════════════════════════════════════════════════
# NEVER COMMIT REAL .env VALUES TO GIT
# ═══════════════════════════════════════════════════════════════════════════════
