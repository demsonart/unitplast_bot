# ═══════════════════════════════════════════════════════════════════════════════
# UNITPLAST BOT - Configuration Template
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git - it contains secrets
#
# ═══════════════════════════════════════════════════════════════════════════════

# TELEGRAM BOT
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here_from_botfather

# Telegram Group ID for notifications (negative number, starts with -100)
# Use @JsonDumpBot in a group to find the group ID
TELEGRAM_GROUP_ID=-1001234567890

# Optional: Admin user ID for admin commands
TELEGRAM_ADMIN_ID=0

# ═══════════════════════════════════════════════════════════════════════════════

# EMAIL (YANDEX MAIL)
# IMAP credentials for automatic order processing
# Use App Password, not your main Yandex password

YANDEX_EMAIL=your_email@yandex.ru
YANDEX_PASSWORD=your_app_password_here
YANDEX_IMAP_SERVER=imap.yandex.ru
YANDEX_IMAP_PORT=993

# Email processing settings
PROCESS_ONLY_UNSEEN=false
EMAIL_CHECK_INTERVAL=300

# ═══════════════════════════════════════════════════════════════════════════════

# COMPANY INFO
# Used in documents, notifications, responses
COMPANY_NAME=Юнитпласт
COMPANY_EMAIL=id@unitplast.ru
COMPANY_EMAIL_SECONDARY=info@unitplast.ru
COMPANY_PHONE=+7 (495) 924-50-96
COMPANY_SITE=www.unitplast.ru
COMPANY_ADDRESS=г. Долгопрудный, ул. Летная, д. 1, территория «ДКБА»
COMPANY_LEGAL_NAME=ИП Демин И. А.

# ═══════════════════════════════════════════════════════════════════════════════

# DATABASE
# Path to SQLite database
DATABASE_PATH=data/unitplast.db

# ═══════════════════════════════════════════════════════════════════════════════

# AI MODE (Optional)
# Enable only if you have Anthropic API key and want AI parsing
ENABLE_AI=false
# ANTHROPIC_API_KEY=sk-ant-...

# ═══════════════════════════════════════════════════════════════════════════════

# FLASK SERVER
# Port for Mini App and API
PORT=5000

# ═══════════════════════════════════════════════════════════════════════════════
