# ═══════════════════════════════════════════════════════════════════════════════
# UNITPLAST BOT - Production Environment Template
# ═══════════════════════════════════════════════════════════════════════════════
#
# COPY THIS FILE TO .env.production ON YOUR PRODUCTION SERVER
# NEVER commit .env.production to git
# Replace all values with your production values
#
# ═══════════════════════════════════════════════════════════════════════════════

# TELEGRAM BOT (REQUIRED)
TELEGRAM_BOT_TOKEN=your_production_bot_token_here
TELEGRAM_GROUP_ID=-1001234567890
TELEGRAM_ADMIN_ID=0

# ═══════════════════════════════════════════════════════════════════════════════

# EMAIL (Optional, for email processing - disable if not needed for MVP)
# If not set, email processing will be skipped
ENABLE_EMAIL_POLLING=false
YANDEX_EMAIL=sales@company.ru
YANDEX_PASSWORD=your_app_password_here
YANDEX_IMAP_SERVER=imap.yandex.ru
YANDEX_IMAP_PORT=993

# ═══════════════════════════════════════════════════════════════════════════════

# DATABASE (Production)
DATABASE_PATH=/app/data/unitplast.db
# Or for PostgreSQL (Phase 2):
# DATABASE_URL=postgresql://user:password@localhost:5432/unitplast

# ═══════════════════════════════════════════════════════════════════════════════

# COMPANY INFO
COMPANY_NAME=Юнитпласт
COMPANY_EMAIL=id@unitplast.ru
COMPANY_EMAIL_SECONDARY=info@unitplast.ru
COMPANY_PHONE=+7 (495) 924-50-96
COMPANY_SITE=unitgroup.tech
COMPANY_ADDRESS=г. Долгопрудный, ул. Летная, д. 1, территория «ДКБА»
COMPANY_LEGAL_NAME=ИП Демин И. А.

# ═══════════════════════════════════════════════════════════════════════════════

# EMAIL PROCESSING (Advanced - Phase 2)
PROCESS_ONLY_UNSEEN=true
EMAIL_CHECK_INTERVAL=300

# ═══════════════════════════════════════════════════════════════════════════════

# AI MODE (Optional)
ENABLE_AI=false
# ANTHROPIC_API_KEY=sk-ant-...

# ═══════════════════════════════════════════════════════════════════════════════

# FLASK/SERVER
PORT=5000
DEBUG=false

# ═══════════════════════════════════════════════════════════════════════════════

# DOMAIN (For logging/reference)
DOMAIN=unitgroup.tech
DOMAIN_WWW=www.unitgroup.tech

# ═══════════════════════════════════════════════════════════════════════════════
